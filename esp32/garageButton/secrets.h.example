// secrets.h is gitignored — never commit it.

#define WIFI_SSID  "your-wifi-ssid"
#define WIFI_PASS  "your-wifi-password"

// Optional — speeds up boot by ~2-3s by skipping the WiFi scan.
// Both must be defined together, or both left commented out.
// To find them: flash without these set, watch serial — the firmware logs
// "BSSID xx:xx:xx:xx:xx:xx  ch N" on connect. Paste those here and re-flash.
// #define WIFI_CHANNEL 11
// static const uint8_t WIFI_BSSID[6] = { 0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF };

#define MQTT_HOST  "xxxx.s1.eu.hivemq.cloud"
#define MQTT_PORT  8883
#define MQTT_USER  "your-mqtt-username"
#define MQTT_PASS  "your-mqtt-password"
#define MQTT_TOPIC "garage/trigger"
